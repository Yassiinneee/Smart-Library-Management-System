{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2020",

    /* Modules */
    "module": "nodeNext",
    "moduleResolution": "nodeNext",

    /* Interoperability */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Type Checking */
    "strict": true,

    /* Output */
    "outDir": "./dist",
    "rootDir": "./src",

    /* Performance */
    "skipLibCheck": true,

    /* Fixes TS1295 Error */
    "verbatimModuleSyntax": false,

    /* Consistency */
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
